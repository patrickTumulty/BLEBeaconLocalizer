{
    "name": "ESP32 Dev (Ubuntu 24)",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "runArgs": [
        "--privileged",
        "--network=host",
        "-v",
        "/dev:/dev",
        "-v",
        "/run/udev:/run/udev:ro"
    ],
    "remoteUser": "root",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "postCreateCommand": "bash -c 'source ${IDF_PATH}/export.sh && idf.py --version && echo \"\n✅ ESP-IDF ready. Run: idf.py create-project my_app\n\"'",
    "forwardPorts": [
        8080,
        8090
    ],
    "mounts": [
        "source=${localEnv:HOME}/.config/nvim,target=/root/.config/nvim,type=bind,consistency=cached"
    ]
}
